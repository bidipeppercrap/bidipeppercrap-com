---
import { Icon } from "astro-icon/components";
import type { Social, SocialPlatform } from "@bidipeppercrap/schema";

interface Props {
  socials: Social[];
}

const { socials } = Astro.props;

// Map semantic platform keys -> Iconify icon names (inlined as SVG at build).
const ICON: Record<SocialPlatform, string> = {
  github: "simple-icons:github",
  instagram: "simple-icons:instagram",
  artstation: "simple-icons:artstation",
  twitter: "simple-icons:x",
  bluesky: "simple-icons:bluesky",
  youtube: "simple-icons:youtube",
  twitch: "simple-icons:twitch",
  mastodon: "simple-icons:mastodon",
  linkedin: "simple-icons:linkedin",
  tiktok: "simple-icons:tiktok",
  discord: "simple-icons:discord",
  email: "lucide:mail",
  website: "lucide:globe",
};
---

<div class="w-full flex justify-center gap-3 flex-wrap">
  {
    socials.map((social) => (
      <a
        aria-label={social.name}
        href={social.targetUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="transition duration-300 ease-in-out border-2 border-white/50 hover:border-white/35 bg-radial from-white from-30% to-white/80 hover:from-white/90 hover:to-white/65 text-[36px] p-6 rounded-3xl shadow-[0_0_16px_rgba(255,255,255,0.20)] hover:shadow-[0_0_8px_rgba(255,255,255,0.10)]"
      >
        <Icon name={ICON[social.platform]} />
      </a>
    ))
  }
</div>
